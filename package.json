{
  "name": "zett",
  "type": "module",
  "version": "0.1.2",
  "description": "Build agents faster than the speed of light.",
  "bin": {
    "zett": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "templates",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": "./dist/index.js",
    "./tools": "./dist/tools/index.js",
    "./skills": "./dist/skills/index.js",
    "./instructions": "./dist/instructions/index.js",
    "./hooks": "./dist/hooks/index.js",
    "./channels": "./dist/channels/index.js",
    "./schedules": "./dist/schedules/index.js",
    "./context": "./dist/context/index.js",
    "./agent": "./dist/agent/index.js",
    "./runner": "./dist/runner/index.js",
    "./auth": "./dist/auth/index.js",
    "./discover": "./dist/discover/index.js",
    "./protocol": "./dist/protocol/events.js"
  },
  "typesVersions": {
    "*": {
      "*": ["./dist/*/index.d.ts", "./dist/index.d.ts"]
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "zett",
    "ai",
    "agent",
    "framework",
    "cencori",
    "filesystem"
  ],
  "author": "Cencori",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cencori/zett.git"
  },
  "homepage": "https://cencori.com",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "ora": "^8.0.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "vitest": "^2.0.0"
  }
}
